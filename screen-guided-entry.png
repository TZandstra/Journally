<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Post | Journally</title>
    <meta name="description" content="Read the latest article from Journally." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function (user) {
          if (!user) {
            window.netlifyIdentity.on("login", function () {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
    <style>
      .post-page {
        min-height: 100svh;
        padding-top: 120px;
        background: var(--ivory);
      }

      .post-article {
        max-width: 820px;
        margin: 0 auto;
        padding: 34px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--surface);
        box-shadow: 0 10px 30px rgba(46, 13, 3, 0.05);
      }

      .post-article img {
        width: 100%;
        margin-bottom: 28px;
        border-radius: 20px;
        aspect-ratio: 16 / 9;
        object-fit: cover;
      }

      .post-meta {
        margin-bottom: 14px;
        color: var(--muted);
        font-weight: 700;
      }

      .post-body {
        color: var(--text);
      }

      .post-body p,
      .post-body ul,
      .post-body ol {
        color: var(--muted);
        font-size: 1.06rem;
      }

      .post-back {
        display: inline-flex;
        margin-bottom: 18px;
        color: var(--orange);
        font-weight: 800;
      }

      @media (max-width: 620px) {
        .post-page {
          padding-top: 150px;
        }

        .post-article {
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="index.html" aria-label="Journally home">
        <img class="brand-logo" src="journally-logo.png" alt="Journally" />
      </a>
      <nav class="nav-links" aria-label="Primaire navigatie">
        <a href="index.html#product">Product</a>
        <a href="index.html#psychologists">Voor psychologen</a>
        <a href="index.html#prototype">Prototype</a>
        <a href="index.html#contact">Contact</a>
        <a href="blog.html">Blog</a>
      </nav>
    </header>

    <main class="post-page">
      <section class="section">
        <div class="section-inner">
          <a class="post-back" href="blog.html">Back to Blog</a>
          <article id="post" class="post-article" aria-live="polite">
            <p class="post-meta">Loading post...</p>
          </article>
        </div>
      </section>
    </main>

    <script>
      const GITHUB_USERNAME = "GITHUB_USERNAME";
      const GITHUB_REPO_NAME = "GITHUB_REPO_NAME";
      const BLOG_FOLDER = "content/blog";
      const postElement = document.querySelector("#post");

      function parseFrontMatter(markdown) {
        const match = markdown.match(/^---\s*([\s\S]*?)\s*---\s*([\s\S]*)$/);
        const data = {};
        const body = match ? match[2].trim() : markdown.trim();
        const frontMatter = match ? match[1] : "";

        frontMatter.split("\n").forEach(function (line) {
          const separatorIndex = line.indexOf(":");
          if (separatorIndex === -1) return;
          const key = line.slice(0, separatorIndex).trim();
          const value = line
            .slice(separatorIndex + 1)
            .trim()
            .replace(/^["']|["']$/g, "");
          data[key] = value;
        });

        return { data: data, body: body };
      }

      function formatDate(value) {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return value || "";
        return date.toLocaleDateString("en", {
          year: "numeric",
          month: "long",
          day: "numeric"
        });
      }

      function renderMarkdown(markdown) {
        return markdown
          .split(/\n{2,}/)
          .map(function (block) {
            const trimmed = block.trim();
            if (!trimmed) return "";
            if (trimmed.startsWith("### ")) return `<h3>${trimmed.slice(4)}</h3>`;
            if (trimmed.startsWith("## ")) return `<h2>${trimmed.slice(3)}</h2>`;
            if (trimmed.startsWith("# ")) return `<h1>${trimmed.slice(2)}</h1>`;
            return `<p>${trimmed.replace(/\n/g, "<br>")}</p>`;
          })
          .join("");
      }

      function renderPost(post) {
        const title = post.data.title || "Untitled post";
        const author = post.data.author || "Journally Team";
        const date = formatDate(post.data.date);
        const thumbnail = post.data.thumbnail || "public/images/welcome-thumbnail.jpeg";

        document.title = title + " | Journally";
        postElement.innerHTML = `
          <img src="${thumbnail}" alt="" />
          <p class="post-meta">${author}${date ? " · " + date : ""}</p>
          <h1>${title}</h1>
          <div class="post-body">${renderMarkdown(post.body)}</div>
        `;
      }

      async function fetchPostFromGitHub(fileName) {
        if (GITHUB_USERNAME === "GITHUB_USERNAME" || GITHUB_REPO_NAME === "GITHUB_REPO_NAME") {
          throw new Error("Add your GitHub username and repository name in post.html.");
        }

        const rawUrl = `https://raw.githubusercontent.com/${GITHUB_USERNAME}/${GITHUB_REPO_NAME}/main/${BLOG_FOLDER}/${fileName}`;
        const response = await fetch(rawUrl);
        if (!response.ok) throw new Error("Could not load this post from GitHub.");
        return parseFrontMatter(await response.text());
      }

      async function loadPost() {
        const params = new URLSearchParams(window.location.search);
        const fileName = params.get("post") || "welcome.md";

        try {
          const post = await fetchPostFromGitHub(fileName);
          renderPost(post);
        } catch (error) {
          renderPost({
            data: {
              title: "Welcome to the Journally blog",
              date: "2026-06-20T09:00:00+02:00",
              author: "Journally Team",
              thumbnail: "public/images/welcome-thumbnail.jpeg"
            },
            body: "Welcome to the Journally blog, where we will share updates, reflections, and articles from the team."
          });
        }
      }

      loadPost();
    </script>
  </body>
</html>
